# Copy → .env và điền giá trị thực. Bật DB để pipeline tự flag NEW_MST / UNKNOWN_PRODUCT
# bằng cách so với customer + product master trong tnbike schema.
#
# Sau khi điền .env, source trước khi chạy pipeline:
#   set -a; source .env; set +a
#   uv run ingest --source-dir "Emails & Files" --out output/

DATABASE_URL=postgresql://duongdd:CHANGE_ME@localhost:5432/tnbike_db

# Optional — psql / pg_dump tự pick lên khi không có flag tương ứng
PGPASSWORD=CHANGE_ME
PGUSER=duongdd
PGDATABASE=tnbike_db
PGHOST=localhost
PGPORT=5432
